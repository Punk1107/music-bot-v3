# Music Bot V3 — Environment Configuration
# Copy this file to .env and fill in your values.

# ─── REQUIRED ────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
APP_ID=your_application_id_here

# ─── SPOTIFY (optional) ───────────────────────────────────────────────────────
# Leave blank to disable Spotify support (YouTube-only mode)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_PATH=data/musicbot.db

# ─── BOT BEHAVIOUR ───────────────────────────────────────────────────────────
# Sync slash commands on startup (only needed after adding/removing commands)
SYNC_COMMANDS=false
# Auto-resume queues on startup from DB
AUTO_RESUME=false
# Auto-disconnect after N seconds of silence (default: 300 = 5 min)
IDLE_TIMEOUT=300
# Max consecutive broken track auto-skips
SKIP_ERROR_LIMIT=5
# Dev channel to forward full tracebacks (leave blank to disable)
DEV_LOG_CHANNEL_ID=

# ─── AUTO-PLAYLIST (V3 NEW) ───────────────────────────────────────────────────
# Auto-fill queue from history when queue becomes empty
AUTO_PLAYLIST=false
AUTO_PLAYLIST_SIZE=5

# ─── FAVORITES (V3 NEW) ───────────────────────────────────────────────────────
MAX_FAVORITES_PER_USER=50

# ─── NLU (V3: Regex engine, no external API) ─────────────────────────────────
NLU_ENABLED=true

# ─── WEBSERVER ────────────────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8080
# Optional bearer token for REST API (empty = no auth required)
API_SECRET=
# REST API requests per minute per IP
API_RATE_LIMIT=60

# ─── AUDIO ───────────────────────────────────────────────────────────────────
YTDL_AUDIO_FORMAT=bestaudio[ext=webm]/bestaudio/best
YTDL_RETRIES=3
YTDL_TIMEOUT=30.0
YTDL_STREAM_TIMEOUT=20.0
YTDL_CACHE_TIMEOUT=1800.0
MAX_TRACK_LENGTH=7200
MAX_PLAYLIST_TRACKS=100
MAX_QUEUE_SIZE=500

# ─── PERFORMANCE ─────────────────────────────────────────────────────────────
# Max concurrent yt-dlp extraction tasks
EXTRACT_CONCURRENCY=3
# Max concurrent dominant-color extraction tasks
COLOR_EXTRACT_CONCURRENCY=3
# Queue auto-save interval in seconds
QUEUE_SAVE_INTERVAL=300

# ─── CIRCUIT BREAKER ─────────────────────────────────────────────────────────
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_WINDOW=60.0

# ─── VOICE RECONNECT ─────────────────────────────────────────────────────────
RECONNECT_ATTEMPTS=3
RECONNECT_BASE_DELAY=2.0
